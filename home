import React, { useState, useEffect } from 'react';
import { View, Text, TextInput, Button, Image, FlatList, StyleSheet, Alert } from 'react-native';
import * as ImagePicker from 'expo-image-picker';
import * as Location from 'expo-location';
import MapView, { Marker } from 'react-native-maps';
import messaging from '@react-native-firebase/messaging';

export default function App() {
  const [photo, setPhoto] = useState(null);
  const [chip, setChip] = useState('');
  const [notes, setNotes] = useState('');
  const [location, setLocation] = useState(null);
  const [rides, setRides] = useState([]);

  useEffect(() => {
    getLocation();
    initNotifications();
  }, []);

  async function getLocation() {
    let { status } = await Location.requestForegroundPermissionsAsync();
    if (status !== 'granted') return;

    let loc = await Location.getCurrentPositionAsync({});
    setLocation(loc.coords);
  }

  async function takePhoto() {
    const result = await ImagePicker.launchCameraAsync({
      mediaTypes: ImagePicker.MediaTypeOptions.Images,
      quality: 0.7,
    });

    if (!result.canceled) {
      setPhoto(result.assets[0].uri);
    }
  }

  function saveRide() {
    const ride = {
      id: Date.now().toString(),
      chip,
      notes,
      photo,
      location,
      date: new Date().toLocaleString(),
    };

    setRides([ride, ...rides]);

    setChip('');
    setNotes('');
    setPhoto(null);

    Alert.alert('Rit opgeslagen', `Rit ${ride.id} is succesvol opgeslagen!`);
  }

  async function initNotifications() {
    await messaging().requestPermission();
    const token = await messaging().getToken();
    console.log('FCM Token:', token);

    messaging().onMessage(async remoteMessage => {
      Alert.alert('Nieuwe melding', remoteMessage.notification.body);
    });
  }

  const RideItem = ({ item }) => (
    <View style={styles.card}>
      <Text style={styles.title}>Rit: {item.date}</Text>
      <Text>Chip: {item.chip || 'Geen'}</Text>
      <Text>Notities: {item.notes}</Text>
      {item.location && (
        <Text>
          GPS: {item.location.latitude.toFixed(5)}, {item.location.longitude.toFixed(5)}
        </Text>
      )}
      {item.photo && <Image source={{ uri: item.photo }} style={styles.image} />}
    </View>
  );

  return (
    <View style={styles.container}>
      <Text style={styles.header}>🚑 Dierenambulance Demo</Text>

      <Button title="Foto maken" onPress={takePhoto} />
      {photo && <Image source={{ uri: photo }} style={styles.image} />}

      <TextInput
        placeholder="Chipnummer"
        value={chip}
        onChangeText={setChip}
        style={styles.input}
      />

      <TextInput
        placeholder="Notities"
        value={notes}
        onChangeText={setNotes}
        style={styles.input}
      />

      <Button title="Rit opslaan" onPress={saveRide} />

      <Text style={styles.subHeader}>🗺 Live Kaart</Text>
      <MapView
        style={styles.map}
        initialRegion={{
          latitude: 52.0907,
          longitude: 5.1214,
          latitudeDelta: 0.05,
          longitudeDelta: 0.05,
        }}
      >
        {rides.map(r => r.location && (
          <Marker
            key={r.id}
            coordinate={{
              latitude: r.location.latitude,
              longitude: r.location.longitude,
            }}
            title={`Rit: ${r.id}`}
            description={r.notes}
          />
        ))}
      </MapView>

      <Text style={styles.subHeader}>📋 Ritlijst</Text>
      <FlatList
        data={rides}
        keyExtractor={item => item.id}
        renderItem={({ item }) => <RideItem item={item} />}
      />
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    padding: 20,
    backgroundColor: '#f5f5f5',
  },
  header: {
    fontSize: 26,
    fontWeight: 'bold',
    marginBottom: 20,
  },
  subHeader: {
    fontSize: 20,
    fontWeight: 'bold',
    marginTop: 20,
    marginBottom: 10,
  },
  input: {
    backgroundColor: 'white',
    padding: 10,
    marginVertical: 8,
    borderRadius: 8,
  },
  card: {
    backgroundColor: 'white',
    padding: 12,
    marginTop: 15,
    borderRadius: 10,
  },
  title: {
    fontWeight: 'bold',
  },
  image: {
    width: '100%',
    height: 200,
    marginTop: 10,
    borderRadius: 10,
  },
  map: {
    width: '100%',
    height: 250,
  },
});
